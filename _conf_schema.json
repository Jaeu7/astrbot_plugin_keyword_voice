{
    "enable": {
        "description": "启用插件",
        "type": "bool",
        "default": true,
        "hint": "是否启用关键词语音回复功能"
    },
    "debug_mode": {
        "description": "调试模式",
        "type": "bool",
        "default": false,
        "hint": "启用后会在日志中输出详细的关键词匹配信息"
    },
    "keyword_voice_mapping": {
        "description": "关键词-语音文件映射",
        "type": "text",
        "default": "{\"哈哈哈\": \"hello.mp3\", \"丑\": \"1.mp3\"}",
        "hint": "JSON格式，key为关键词，value为语音文件名"
    },
    "voices_dir": {
        "description": "语音文件目录",
        "type": "string",
        "default": "voices",
        "hint": "语音文件存放的目录，相对于插件目录"
    },
    "fallback_to_text": {
        "description": "语音文件缺失时回退到文本",
        "type": "bool",
        "default": true,
        "hint": "当语音文件不存在时，是否发送文本提示"
    }
}